# Database Configuration
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=iaas_db

# JWT Configuration
JWT_SECRET=GenerateItUsingOpenssl

# RabbitMQ Configuration
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_PORT=5672
RABBITMQ_UI_PORT=15672
QUEUE_NAME=hardware_requests

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
CONSULTER_RESPONSE_QUEUE=chat_requests

# Frontend Configuration
FRONTEND_PORT=80

# CORS (comma-separated origins, added to defaults)
CORS_ORIGINS=https://your-domain.com

# Logging
LOG_LEVEL=INFO
